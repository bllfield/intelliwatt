{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "app/api/admin/smt/pull/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/admin/smt/normalize/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/user/usage/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/user/usage/simulated/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/user/usage/simulated/house/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/admin/tools/gapfill-lab/route.ts": {
      "maxDuration": 120,
      "memory": 3008
    },
    "app/api/admin/tools/prime-past-cache/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "crons": [
    { "path": "/api/admin/ercot/cron", "schedule": "0 12 * * *" },
    { "path": "/api/admin/tdsp/ingest", "schedule": "15 9 * * *" },
    { "path": "/api/admin/wattbuy/cron/nightly", "schedule": "*/5 * * * *" },
    { "path": "/api/admin/smt/cron/pull-sample", "schedule": "*/5 * * * *" }
  ]
}
