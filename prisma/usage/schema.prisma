/// NOTE: This schema is dedicated to the Usage module.
/// - Uses its own migrations directory: prisma/usage/migrations
/// - Points at USAGE_DATABASE_URL for its datasource.
/// - Generate/run Prisma commands with:
///     --schema=prisma/usage/schema.prisma
///     --migrations-dir=prisma/usage/migrations

generator usageClient {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output        = "../../.prisma/usage-client"
}

datasource usageDb {
  provider = "postgresql"
  url      = env("USAGE_DATABASE_URL")
  directUrl = env("USAGE_DIRECT_URL")
}

enum DayType {
  ALL
  WEEKDAY
  WEEKEND
}

enum Season {
  ALL
  SUMMER
  WINTER
  SHOULDER
}

enum OvernightAttribution {
  ACTUAL_DAY
  START_DAY
}

enum IntervalSeriesKind {
  ACTUAL_USAGE_INTERVALS
  BASELINE_INTERVALS
  PAST_SIM_BASELINE
  FUTURE_SIM_BASELINE
  FUTURE_SIM_USAGE
}

/// Section 13 / UNIFIED_SIM_FINGERPRINT_PLAN: fingerprint row lifecycle (not a second artifact family).
enum SimulatorFingerprintStatus {
  ready
  stale
  building
  failed
}

model UsageModuleBootstrap {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

model UsageIntervalModule {
  id        String   @id @default(cuid())
  esiid     String
  meter     String
  ts        DateTime
  kwh       Decimal  @usageDb.Decimal(10, 5)
  filled    Boolean  @default(false)
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([esiid, meter, ts])
  @@index([ts])
  @@index([esiid, meter, ts])
}

model RawGreenButton {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeId String?
  userId String?

  utilityName   String?
  accountNumber String?

  filename  String
  mimeType  String
  sizeBytes Int
  content   Bytes

  sha256     String?   @unique
  capturedAt DateTime?

  @@index([homeId])
  @@index([userId])
}

model GreenButtonInterval {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  rawId           String
  homeId          String?
  userId          String?
  timestamp       DateTime
  consumptionKwh  Decimal  @usageDb.Decimal(10, 5)
  intervalMinutes Int      @default(15)

  @@index([rawId])
  @@index([timestamp])
  @@index([rawId, timestamp])
  @@index([homeId, timestamp])
}

model UsageBucketDefinition {
  id        String   @id @default(cuid())
  key       String   @unique // canonical key: kwh.m.<dayType>.<start>-<end>[.<season>]
  label     String
  dayType   DayType
  season    Season?
  startHHMM String
  endHHMM   String
  tz        String
  overnightAttribution OvernightAttribution @default(ACTUAL_DAY)
  ruleJson  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  monthly   HomeMonthlyUsageBucket[]
  daily     HomeDailyUsageBucket[]
  simulated HomeSimulatedUsageBucket[]

  @@index([dayType])
}

model HomeMonthlyUsageBucket {
  id         String   @id @default(cuid())
  homeId     String
  yearMonth  String // "YYYY-MM"
  bucketKey  String // FK by key (string) to keep lookups stable across environments
  kwhTotal   Decimal  @usageDb.Decimal(12, 6)
  source     String
  computedAt DateTime @default(now())

  bucket UsageBucketDefinition @relation(fields: [bucketKey], references: [key], onDelete: Restrict, onUpdate: Cascade)

  @@unique([homeId, yearMonth, bucketKey])
  @@index([homeId, yearMonth])
  @@index([bucketKey])
}

model HomeDailyUsageBucket {
  id        String   @id @default(cuid())
  homeId    String
  day       String // "YYYY-MM-DD" (America/Chicago local date)
  bucketKey String // references UsageBucketDefinition.key
  kwhTotal  Decimal  @usageDb.Decimal(12, 6)
  source    String
  computedAt DateTime @default(now())

  bucket UsageBucketDefinition @relation(fields: [bucketKey], references: [key], onDelete: Restrict, onUpdate: Cascade)

  @@unique([homeId, day, bucketKey])
  @@index([homeId, day])
  @@index([bucketKey])
}

model HomeSimulatedUsageBucket {
  id          String   @id @default(cuid())
  homeId      String
  scenarioKey String   // "PAST" | "FUTURE" (workspace scenario key)
  scenarioId  String?  // usageSimulatorScenario.id when scenarioKey is scenario id
  yearMonth   String   // "YYYY-MM"
  bucketKey   String   // references UsageBucketDefinition.key
  kwhTotal    Decimal  @usageDb.Decimal(12, 6)
  source      String   @default("SIMULATED")
  computedAt  DateTime @default(now())

  bucket UsageBucketDefinition @relation(fields: [bucketKey], references: [key], onDelete: Restrict, onUpdate: Cascade)

  @@unique([homeId, scenarioKey, yearMonth, bucketKey])
  @@index([homeId, scenarioKey])
  @@index([bucketKey])
}

model IntervalSeries {
  id                String             @id @default(uuid())
  userId            String
  houseId           String
  kind              IntervalSeriesKind
  scenarioId        String?
  anchorStartUtc    DateTime
  anchorEndUtc      DateTime
  derivationVersion String
  buildInputsHash   String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  points IntervalPoint15m[]

  @@index([userId])
  @@index([houseId])
  @@index([kind])
  @@index([scenarioId])
  @@index([userId, houseId, kind])
  @@index([userId, houseId, kind, scenarioId])
}

model IntervalPoint15m {
  seriesId String
  tsUtc    DateTime
  kwh      Decimal @usageDb.Decimal(12, 6)

  series IntervalSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@id([seriesId, tsUtc])
  @@index([tsUtc])
}

/// Versioned usage shape derived from actual 15-min intervals (canonical 12-month window). houseId references HouseAddress.id in main DB.
model UsageShapeProfile {
  id                        String    @id @default(cuid())
  houseId                   String
  version                   String
  derivedAt                 DateTime  @default(now())
  windowStartUtc            DateTime
  windowEndUtc              DateTime
  baseloadKwhPer15m         Float?
  baseloadKwhPerDay         Float?
  shapeAll96                Json?
  shapeWeekday96            Json?
  shapeWeekend96            Json?
  shapeByMonth96            Json?
  avgKwhPerDayWeekdayByMonth Json?
  avgKwhPerDayWeekendByMonth Json?
  peakHourByMonth           Json?
  p95KwByMonth              Json?
  timeOfDayShares           Json?
  configHash                String

  @@unique([houseId, version])
  @@index([houseId])
}

/// Persisted WholeHomeFingerprint artifact (Phase 2a). One logical row per house (upsert).
/// Modeled outputs remain PastSimulatedDatasetCache / shared sim chain only.
model WholeHomeFingerprint {
  id               String   @id @default(cuid())
  houseId          String
  /// Section 13 state: ready | stale | building | failed
  status           SimulatorFingerprintStatus
  /// Builder / algorithm revision (e.g. semver or internal tag).
  algorithmVersion String
  /// Dependency hash over inputs that define validity (per plan Section 13).
  sourceHash       String
  /// Set when status is stale or failed (operator- or machine-readable).
  staleReason      String?
  /// Last successful materialization (null when never built successfully).
  builtAt          DateTime?
  /// Serialized fingerprint payload or structured JSON per builder contract.
  payloadJson      Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([houseId])
  @@index([houseId])
  @@index([status])
  @@index([sourceHash])
}

/// Persisted UsageFingerprint artifact (Phase 2a). One logical row per house (upsert).
model UsageFingerprint {
  id               String   @id @default(cuid())
  houseId          String
  status           SimulatorFingerprintStatus
  algorithmVersion String
  sourceHash       String
  staleReason      String?
  builtAt          DateTime?
  payloadJson      Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([houseId])
  @@index([houseId])
  @@index([status])
  @@index([sourceHash])
}

/// Cache for Past simulated dataset (one canonical builder; avoid full rebuild on every GET).
model PastSimulatedDatasetCache {
  id                  String   @id @default(cuid())
  houseId             String
  scenarioId          String   // scenario UUID for Past, or "gapfill_lab"
  windowStartUtc      String   // YYYY-MM-DD
  windowEndUtc        String   // YYYY-MM-DD
  inputHash           String   // hash of buildInputs + travelRanges + timezone + window + engineVersion
  engineVersion       String   // e.g. "production_past_stitched_v1"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  datasetJson         Json     // summary + monthly + metadata (no full intervals)
  intervalsCodec      String   // "v1_delta_varint"
  intervalsCompressed Bytes    // compressed packed intervals

  @@unique([houseId, scenarioId, inputHash])
  @@index([houseId, scenarioId])
}

/// Durable compare-core run lifecycle + compact snapshot handoff for staged heavy readers.
model GapfillCompareRunSnapshot {
  id                        String    @id @default(cuid()) // compareRunId
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  startedAt                 DateTime  @default(now())
  finishedAt                DateTime?
  status                    String    // started | running | succeeded | failed
  phase                     String?

  houseId                   String?
  userId                    String?
  compareFreshMode          String

  requestedInputHash        String?
  artifactScenarioId        String?
  requireExactArtifactMatch Boolean   @default(false)
  artifactIdentitySource    String?

  failureCode               String?
  failureMessage            String?
  snapshotReady             Boolean   @default(false)
  snapshotVersion           String?
  snapshotPersistedAt       DateTime?
  snapshotJson              Json?
  /// Full normalized compare inputs for async replay (droplet worker); not used as simulated output.
  queuedPayloadJson         Json?
  statusMetaJson            Json?

  @@index([houseId, createdAt])
  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

/// Global reusable lab test-home mapping for canonical Gap-Fill calibration flow.
model GapfillLabTestHomeLink {
  id              String   @id @default(cuid())
  ownerUserId     String   @unique
  testHomeHouseId String
  sourceUserId    String?
  sourceHouseId   String?
  status          String   @default("ready") // ready | replacing | profile_syncing | failed
  statusMessage   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastReplacedAt  DateTime?

  @@index([testHomeHouseId])
  @@index([sourceUserId, sourceHouseId])
  @@index([status, updatedAt])
}

/// Dedicated reusable lab test-home mapping for One Path admin isolation.
model OnePathLabTestHomeLink {
  id              String   @id @default(cuid())
  ownerUserId     String   @unique
  testHomeHouseId String
  sourceUserId    String?
  sourceHouseId   String?
  status          String   @default("ready") // ready | replacing | profile_syncing | failed
  statusMessage   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastReplacedAt  DateTime?

  @@index([testHomeHouseId])
  @@index([sourceUserId, sourceHouseId])
  @@index([status, updatedAt])
}

/// System-wide canonical validation-day selection defaults.
model UsageSimulatorSettings {
  /// Singleton key. Use "default" for the active record.
  id                               String   @id @default("default")
  userDefaultValidationSelectionMode String @default("random_simple")
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}

/// Generic async droplet execution queue for shared sim workloads (Past recalc, etc.). Gap-Fill compare uses GapfillCompareRunSnapshot + compareRunId.
model SimDropletJob {
  id             String   @id @default(uuid())
  jobKind        String   // e.g. past_sim_recalc
  status         String   // queued | running | succeeded | failed
  payloadJson    Json
  failureMessage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([jobKind, status])
}
